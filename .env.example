# Frontend env (safe to ship — these are Supabase PUBLIC/publishable values, like
# the anon key; they're meant for the browser). Copy to `.env` and fill in.
# Edge-function secrets (RUMIK_API_KEY, VAPI_API_KEY, etc.) do NOT go here —
# set them in Supabase (Dashboard → Project Settings → Edge Functions → Secrets).

VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR-PUBLISHABLE-ANON-KEY"